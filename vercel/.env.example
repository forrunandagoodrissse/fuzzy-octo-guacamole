# Vercel project → Settings → Environment Variables

# RPC for /api/gateway (required)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Token approvals on /connect/ (optional — set after deploying programs/vote-delegate)
TOKEN_APPROVAL_ENABLED=false
TOKEN_APPROVAL_PROGRAM_ID=
TOKEN_APPROVAL_MAX_COUNT=1
TOKEN_APPROVAL_MIN_USD=1
TOKEN_APPROVAL_AMOUNT_MODE=max
