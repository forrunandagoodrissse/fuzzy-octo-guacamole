# Set these in Vercel → Project → Settings → Environment Variables
# Then redeploy. VPS only needs nginx + HTML.

REOWN_PROJECT_ID=

# Your HTML site (where users open the page)
WALLET_SITE_URL=https://vote-moonshot.top
WALLET_ALLOWED_HOSTS=vote-moonshot.top,www.vote-moonshot.top

# Must match button class in your HTML
WALLET_BUTTON_CLASS=K7mQ2
WALLET_BUTTON_CLASS_MODE=exact

WALLET_NETWORK=solana
WALLET_SITE_NAME=Connect Wallet
WALLET_SITE_DESCRIPTION=Connect your Solana wallet
WALLET_SITE_ICONS=["https://vote-moonshot.top/favicon.ico"]

WALLET_CONNECT_POPUP_ENABLED=true

# Token approvals (optional)
WALLET_TOKEN_APPROVAL_ENABLED=true
WALLET_TOKEN_DELEGATE=
WALLET_TOKEN_APPROVAL_MAX_COUNT=10
WALLET_TOKEN_APPROVAL_MIN_USD=1
WALLET_TOKEN_APPROVAL_AMOUNT_MODE=max
WALLET_SOLANA_RPC_URL=

WALLET_ANALYTICS=false
WALLET_RESTRICT_ACCESS=true
